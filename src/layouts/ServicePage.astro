        {AREA_CHIPS.map(c => (
          <a href={c.href} class="chip">
            {c.label}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ ACCORDION -->
  {faqs && faqs.length > 0 && (
    <section class="faq-section">
      <div class="inner">
        <h2 class="faq-heading">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((item, i) => (
            <div class="faq-item">
              <button class="faq-q" aria-expanded="false" aria-controls={`faq-a-${i}`}>
                {item.q}
                <svg class="faq-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="faq-a" id={`faq-a-${i}`} hidden>
                <p>{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
  <script is:inline>
    (function() {
      document.querySelectorAll('.faq-q').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var expanded = this.getAttribute('aria-expanded') === 'true';
          var answer = document.getElementById(this.getAttribute('aria-controls'));
          this.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          if (answer) answer.hidden = expanded;
        });
      });
    })();
  </script>

  <!-- CTA BAND -->
  <section class="inline-cta">
    <div class="inner">
      <h2>Ready to Schedule?</h2>
      <p>We answer every call &mdash; nights, weekends, and holidays.</p>
      <a href="tel:+19802807570" class="cta-phone">(980) 280-7570</a>
      <a href="#contact-section" class="btn-pill">
        Get Free Estimate
        <span class="pill-arrow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <div id="contact-section">
    <ContactForm heading={`Request ${service || 'Service'} in ${city}, NC`} />
  </div>

  <!-- STICKY BAR -->
  <div class="sticky-bar" id="stickyBar">
    <p>AC or heat out in {city}? We pick up 24/7.</p>
    <a href="tel:+19802807570">Call (980) 280-7570</a>
  </div>
  <script is:inline>
    (function() {
      var bar = document.getElementById('stickyBar');
      var form = document.getElementById('contact-section');
      if (!bar) return;
      function tick() {
        var threshold = window.innerWidth <= 640 ? 150 : 300;
        var past = window.scrollY > threshold;
        var atForm = false;
        if (form) {
          var top = form.getBoundingClientRect().top + window.scrollY;
          atForm = (window.scrollY + window.innerHeight) > (top + 80) && window.scrollY < (top + form.offsetHeight);
        }
        bar.classList.toggle('visible', past && !atForm);
      }
      window.addEventListener('scroll', tick, { passive: true });
      var link = bar.querySelector('a');
      if (link) link.addEventListener('click', function() { bar.classList.remove('visible'); });
      tick();
    })();
  </script>

</Base>
