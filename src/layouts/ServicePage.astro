            <span class="how-chip-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="how-chip-text">We answer 24/7 &mdash; (980) 280-7570</span>
          </a>
        </div>
      </div>
    </div>
  </section>
  <script is:inline>
    (function() {
      var s = document.getElementById('howItWorks');
      if (!s) return;
      s.classList.add('js-anim');
      if (!('IntersectionObserver' in window)) { s.classList.add('in'); return; }
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) { if (e.isIntersecting) { s.classList.add('in'); io.disconnect(); } });
      }, { threshold: 0.25 });
      io.observe(s);
    })();
  </script>

