---
import Base from './Base.astro';
import ContactForm from '../components/ContactForm.astro';
import TrustBar from '../components/TrustBar.astro';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  city?: string;
  lastmod?: string;
}
const { title, description, canonical, city = 'Monroe' } = Astro.props;

const citySchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Bryant Heating & Cooling",
  "description": description,
  "telephone": "(980) 280-7570",
  "areaServed": { "@type": "City", "name": city, "addressRegion": "NC" }
};
---
<Base title={title} description={description} canonical={canonical} schema={citySchema}>
  <div class="inner" style="padding-top:32px;"><TrustBar /></div>
  <article class="inner" style="padding:48px 24px; max-width:860px;">
    <slot />
  </article>
  <ContactForm heading={`HVAC Service in ${city}, NC`} />
</Base>
