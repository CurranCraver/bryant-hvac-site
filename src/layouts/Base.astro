---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: object;
}
const { title, description, canonical, schema } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HVACBusiness",
  "name": "Bryant Heating & Cooling",
  "legalName": "Bryant Heating and Cooling of the Piedmont, LLC",
  "url": "https://bryanthvacpros.com",
  "telephone": "(980) 280-7570",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "7923 Morgan Mill Rd",
    "addressLocality": "Monroe",
    "addressRegion": "NC",
    "postalCode": "28110",
    "addressCountry": "US"
  },
  "hasCredential": "NC Contractor License #18740",
  "priceRange": "$$",
  "openingHours": "Mo-Su 00:00-23:59",
  "sameAs": ["https://www.facebook.com/p/Bryant-Heating-Cooling-61572909688382/"]
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;600;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  <style is:global>
    :root {
      --red: #C41E1E;
      --blue: #5B8AB5;
      --navy: #1B3A5C;
      --white: #FFFFFF;
      --bg: #F0F4F8;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Barlow', sans-serif; font-size: 16px; color: #111; background: var(--white); }
    h1, h2, h3 { font-family: 'Barlow Condensed', sans-serif; font-weight: 800; }
    a { color: var(--red); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  </style>
</head>
<body>
  <slot name="header">
    <header style="background:var(--navy); padding:16px 0;">
      <div class="inner" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
        <a href="/">
          <img src="/images/bryant-hvac-logo.webp" alt="Bryant Heating & Cooling" style="height:48px; width:auto;" />
        </a>
        <nav style="display:flex; gap:24px; align-items:center; flex-wrap:wrap;">
          <a href="/service-areas" style="color:#fff; font-weight:600;">Service Areas</a>
          <a href="/about" style="color:#fff; font-weight:600;">About</a>
          <a href="/contact" style="color:#fff; font-weight:600;">Contact</a>
          <a href="tel:+19802807570"
             style="background:var(--red); color:#fff; padding:10px 20px; border-radius:4px; font-weight:700; white-space:nowrap; flex-shrink:0;">
            (980) 280-7570
          </a>
        </nav>
      </div>
    </header>
  </slot>

  <main><slot /></main>

  <slot name="footer">
    <footer style="background:var(--navy); color:#fff; padding:48px 0; margin-top:64px;">
      <div class="inner">
        <p style="font-weight:700; font-size:18px;">Bryant Heating & Cooling</p>
        <p style="margin-top:8px;">7923 Morgan Mill Rd, Monroe, NC 28110</p>
        <p><a href="tel:+19802807570" style="color:#fff;">(980) 280-7570</a></p>
        <p style="margin-top:8px; font-size:14px; opacity:0.7;">NC Contractor License #18740 · Licensed & Insured · BBB Accredited</p>
        <p style="margin-top:16px; font-size:13px; opacity:0.6;">
          <a href="/privacy-policy" style="color:#fff;">Privacy Policy</a> ·
          <a href="/terms-of-service" style="color:#fff;">Terms of Service</a>
        </p>
      </div>
    </footer>
  </slot>
</body>
</html>
