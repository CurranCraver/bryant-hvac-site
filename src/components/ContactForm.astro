---
export interface Props {
  heading?: string;
}
const { heading = "Request Service" } = Astro.props;
---
<section style="background:var(--bg); padding:64px 0;">
  <div class="inner" style="max-width:600px;">
    <h2 style="font-size:2rem; color:var(--navy); margin-bottom:24px;">{heading}</h2>
    <form action="/.netlify/functions/contact" method="POST"
          style="display:flex; flex-direction:column; gap:16px;">
      <input name="name" type="text" required placeholder="Your name"
             style="padding:12px 16px; border:1px solid #ccc; border-radius:4px; font-size:16px; font-family:inherit;" />
      <input name="phone" type="tel" required placeholder="Phone number"
             style="padding:12px 16px; border:1px solid #ccc; border-radius:4px; font-size:16px; font-family:inherit;" />
      <input name="email" type="email" placeholder="Email (optional)"
             style="padding:12px 16px; border:1px solid #ccc; border-radius:4px; font-size:16px; font-family:inherit;" />
      <textarea name="message" placeholder="What do you need?" rows="4"
                style="padding:12px 16px; border:1px solid #ccc; border-radius:4px; font-size:16px; font-family:inherit; resize:vertical;"></textarea>
      <label style="display:flex; gap:10px; align-items:flex-start; font-size:13px; color:#555; cursor:pointer; line-height:1.5;">
        <input name="sms_consent" type="checkbox" style="margin-top:2px; flex-shrink:0;" />
        By checking this box, I consent to receive non-marketing text messages from Bryant Heating &amp; Cooling of the Piedmont, LLC about service requests and follow-up communications. Message frequency varies, message &amp; data rates may apply. Text HELP for assistance, reply STOP to opt out.
      </label>
      <label style="display:flex; gap:10px; align-items:flex-start; font-size:13px; color:#555; cursor:pointer; line-height:1.5;">
        <input name="marketing_consent" type="checkbox" style="margin-top:2px; flex-shrink:0;" />
        By checking this box, I consent to receive marketing text messages about special offers, discounts, and service updates from Bryant Heating &amp; Cooling of the Piedmont, LLC at the phone number provided. Message frequency may vary. Message &amp; data rates may apply. Text HELP for assistance, reply STOP to opt out.
      </label>
      <p style="font-size:12px; color:#888; margin-top:-8px;">
        By submitting this form you agree to our
        <a href="/privacy-policy">Privacy Policy</a> and
        <a href="/terms-of-service">Terms of Service</a>.
      </p>
      <button type="submit"
              style="background:var(--red); color:#fff; padding:14px 32px; border:none; border-radius:4px; font-size:1.2rem; font-weight:700; font-family:'Barlow Condensed',sans-serif; cursor:pointer; letter-spacing:0.5px;">
        Request Service →
      </button>
    </form>
  </div>
</section>
