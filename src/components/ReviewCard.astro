---
export interface Props {
  text: string;
  author: string;
  rating?: number;
}
const { text, author, rating = 5 } = Astro.props;
---
<div style="background:#fff; border:1px solid #e2e8f0; border-radius:8px; padding:24px;">
  <div style="color:#f59e0b; font-size:18px; margin-bottom:8px;" aria-label={`${rating} stars`}>
    {'★'.repeat(rating)}
  </div>
  <p style="font-size:15px; line-height:1.6; color:#374151; font-style:italic;">"{text}"</p>
  <p style="margin-top:12px; font-weight:700; color:var(--navy);">— {author}</p>
</div>
