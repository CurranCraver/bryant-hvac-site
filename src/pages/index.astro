  <script is:inline>
    (function() {
      // Read More toggle
      var btn = document.getElementById('readMoreBtn');
      var more = document.getElementById('introMore');
      if (btn && more) {
        btn.addEventListener('click', function() {
          var open = more.classList.toggle('open');
          btn.classList.toggle('open', open);
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          btn.querySelector('.rm-label').textContent = open ? 'Read Less' : 'Read More';
        });
      }
      // Sticky bar
      var bar = document.getElementById('stickyBar');
      var hero = document.getElementById('hero');
      if (bar && hero) {
        function updateBar() {
          var heroBottom = hero.offsetTop + hero.offsetHeight;
          bar.classList.toggle('visible', window.scrollY > heroBottom - 80);
        }
        window.addEventListener('scroll', updateBar, { passive: true });
        var barLink = bar.querySelector('a');
        if (barLink) barLink.addEventListener('click', function() { bar.classList.remove('visible'); });
        updateBar();
      }
    })();
  </script>
