---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---
<Base
  title="Bryant Heating &amp; Cooling | HVAC Indian Trail, Monroe &amp; Charlotte NC"
  description="Family-owned HVAC for Union County &amp; greater Charlotte. AC repair, heating, heat pumps, installation &amp; maintenance — licensed #18740, 24/7, no diagnostic fee. Call (980) 280-7570."
  canonical="https://bryanthvacpros.com"
  preloadImage="/images/bryant-real-12.jpg"
>
  <style>
    :root {
      --red-dark: #A31818;
      --light-bg: #F0F4F8;
      --text: #2A2A2A;
      --muted: #5a6675;
      --border: #E2E8EF;
    }
    html { scroll-behavior: smooth; }
    body { overflow-x: hidden; }
    .section-eyebrow { font-family: var(--font-heading); font-size: 0.78rem; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
    .anton { font-family: var(--font-display); font-weight: 400; letter-spacing: 0.5px; text-transform: uppercase; line-height: 1.04; }

    /* ─── HERO ─────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 560px;
      display: flex;
      align-items: center;
      padding: 76px 0 84px;
      background: linear-gradient(to right, rgba(27,58,92,0.93) 0%, rgba(27,58,92,0.93) 38%, rgba(27,58,92,0.60) 52%, rgba(27,58,92,0.08) 65%, rgba(27,58,92,0.00) 100%), url('/images/bryant-real-12.jpg') 70% 18%/cover no-repeat;
    }
    .hero-inner { max-width: 640px; }
    .hero h1 { font-size: clamp(38px, 5.6vw, 66px); color: var(--white); }
    .hero-sub { font-family: var(--font-body); font-size: clamp(16px, 1.5vw, 19px); color: rgba(255,255,255,0.88); margin-top: 18px; line-height: 1.6; max-width: 620px; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
    .btn-pill {
      display: inline-flex; align-items: center; gap: 10px;
      background: var(--red); color: var(--white);
      padding: 14px 16px 14px 26px; border-radius: 100px;
      font-family: var(--font-heading); font-weight: 700; font-size: 1rem;
      text-transform: uppercase; letter-spacing: 0.5px;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-pill:hover { background: var(--red-dark); transform: translateY(-2px); text-decoration: none; }
    .btn-pill .pill-arrow { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.22); transition: transform 0.2s; }
    .btn-pill:hover .pill-arrow { transform: translateX(3px); }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 9px;
      background: transparent; color: var(--white);
      border: 2px solid rgba(255,255,255,0.55);
      padding: 13px 26px; border-radius: 100px;
      font-family: var(--font-heading); font-weight: 700; font-size: 1rem;
      text-transform: uppercase; letter-spacing: 0.5px;
      transition: background 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.12); border-color: #fff; text-decoration: none; }
    .hero-stars { display: flex; align-items: center; gap: 9px; margin-top: 22px; }
    .hero-stars .stars { color: #FFC107; font-size: 1rem; letter-spacing: 2px; }
    .hero-stars span.txt { font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; color: rgba(255,255,255,0.9); text-transform: uppercase; letter-spacing: 0.5px; }
    .hero-watermark {
      position: absolute;
      right: 5%;
      bottom: -40px;
      height: 290px;
      width: auto;
      opacity: 0.11;
      filter: grayscale(1) brightness(10);
      pointer-events: none;
      user-select: none;
    }
    @media (max-width: 860px) { .hero-watermark { display: none; } }

    /* ─── ACTION CARDS (overlap hero bottom) ───────────── */
    /* Cards live in their OWN section — no negative-margin overlap (a card row taller than the
       overlap straddles the hero/white seam and looks broken). See website-build-checklist.md. */
    .action-wrap { position: relative; padding: 48px 0; }
    .action-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1100px; width: 100%; margin: 0 auto; padding: 0 24px; }
    .action-card {
      border-radius: 12px; padding: 28px 22px 24px;
      box-shadow: 0 18px 40px rgba(27,58,92,0.18);
      display: flex; flex-direction: column; align-items: center; text-align: center; min-height: 178px;
      transition: transform 0.18s, box-shadow 0.18s;
      text-decoration: none;
    }
    .action-card:hover { transform: translateY(-5px); box-shadow: 0 24px 50px rgba(27,58,92,0.26); text-decoration: none; }
    .action-card .ac-icon { width: 42px; height: 42px; margin-bottom: 16px; }
    .action-card .ac-title { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; line-height: 1.05; letter-spacing: 0.3px; text-transform: uppercase; }
    .action-card .ac-sub { font-family: var(--font-heading); font-weight: 700; font-size: 0.92rem; margin-top: auto; padding-top: 12px; display: inline-flex; align-items: center; gap: 6px; }
    .action-card.red { background: linear-gradient(160deg, #d62525 0%, var(--red) 60%, var(--red-dark) 100%); color: #fff; }
    .action-card.red .ac-icon, .action-card.red .ac-sub { color: #fff; }
    .action-card.blue { background: linear-gradient(160deg, #2f5d8a 0%, var(--navy) 100%); color: #fff; }
    .action-card.blue .ac-icon, .action-card.blue .ac-sub { color: rgba(255,255,255,0.92); }
    .action-card.light { background: #fff; color: var(--navy); }
    .action-card.light .ac-icon { color: var(--navy); }
    .action-card.light .ac-sub { color: var(--red); }

    /* ─── SERVICES BAND ────────────────────────────────── */
    .services-band {
      position: relative;
      padding: 76px 0 80px;
      background: linear-gradient(rgba(27,58,92,0.93), rgba(27,58,92,0.93)), url('/images/hvac-panel-3.jpg') center/cover no-repeat fixed;
    }
    .services-head { text-align: center; margin-bottom: 44px; }
    .services-head .section-eyebrow { color: rgba(255,255,255,0.75); }
    .services-head h2 { font-size: clamp(30px, 4vw, 46px); color: #fff; }
    .divider { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 18px; }
    .divider .line { height: 2px; width: 110px; background: rgba(255,255,255,0.45); }
    .divider .gear { color: var(--red); }
    .svc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .svc-card {
      background: #fff; border-radius: 10px; padding: 34px 22px;
      text-align: center; text-decoration: none;
      box-shadow: 0 10px 30px rgba(0,0,0,0.18);
      border-bottom: 4px solid transparent;
      transition: transform 0.18s, border-color 0.18s;
    }
    .svc-card:hover { transform: translateY(-5px); border-bottom-color: var(--red); text-decoration: none; }
    .svc-card .svc-icon { width: 52px; height: 52px; color: var(--navy); margin-bottom: 16px; }
    .svc-card:hover .svc-icon { color: var(--red); }
    .svc-card h3 { font-family: var(--font-display); font-weight: 400; font-size: 1.5rem; letter-spacing: 0.4px; text-transform: uppercase; color: var(--red); }
    .svc-card p { font-family: var(--font-body); font-size: 0.9rem; color: var(--muted); margin-top: 8px; }

    /* ─── WHY CHOOSE BAND ──────────────────────────────── */
    .why-band {
      position: relative; overflow: hidden;
      margin: 72px auto; max-width: 1100px; width: calc(100% - 48px); border-radius: 14px;
      min-height: 420px; display: flex; align-items: center;
    }
    .why-band::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background: linear-gradient(100deg, rgba(27,58,92,0.94) 0%, rgba(27,58,92,0.78) 45%, rgba(27,58,92,0.30) 100%), url('/images/bryant-real-2014.jpg') 60% 30%/cover no-repeat;
    }
    .why-content { position: relative; z-index: 1; padding: 56px 48px; max-width: 640px; }
    .why-content h2 { font-size: clamp(30px, 4.2vw, 52px); color: #fff; }
    .why-content p { font-family: var(--font-body); font-size: 1.02rem; line-height: 1.7; color: rgba(255,255,255,0.88); margin-top: 18px; }
    .why-content .btn-pill { margin-top: 28px; }
    @media (max-width: 760px) { .why-band { margin: 48px 16px; min-height: 0; } .why-content { padding: 40px 26px; } }

    /* ─── SPLIT PANEL (replaces dead intro text — locked service-page mechanic, design_rules.md) ─── */
    .split-panel { background: #fff; display: grid; grid-template-columns: 1fr 1fr; min-height: 440px; }
    .split-panel.flip .split-img { order: 2; }
    .split-panel.flip .split-text { order: 1; background: var(--bg); }
    .split-img { overflow: hidden; }
    .split-img img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; transition: transform 0.5s ease; }
    .split-img:hover img { transform: scale(1.04); }
    .split-text { padding: 60px 52px; display: flex; flex-direction: column; justify-content: center; }
    .split-eyebrow { font-family: var(--font-heading); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--red); margin-bottom: 10px; }
    .split-heading { font-family: var(--font-display); font-weight: 400; font-size: clamp(1.8rem, 3.2vw, 2.5rem); color: var(--navy); line-height: 1.07; letter-spacing: 0.3px; text-transform: uppercase; margin-bottom: 16px; }
    .split-lead { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.7; color: #3a444f; margin-bottom: 22px; }
    .split-list { list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 12px; }
    .split-list li { font-family: var(--font-body); font-size: 0.97rem; color: #333; display: flex; align-items: flex-start; gap: 10px; line-height: 1.5; }
    .split-list li svg { color: var(--red); flex-shrink: 0; margin-top: 3px; }
    .btn-red-sm { display: inline-flex; align-items: center; gap: 8px; align-self: flex-start; background: var(--red); color: #fff; padding: 13px 26px; border-radius: 6px; font-family: var(--font-heading); font-weight: 700; font-size: 0.92rem; text-transform: uppercase; letter-spacing: 0.5px; transition: background 0.2s, transform 0.15s; }
    .btn-red-sm:hover { background: var(--red-dark); transform: translateY(-2px); text-decoration: none; }
    @media (max-width: 820px) {
      .split-panel { grid-template-columns: 1fr; }
      .split-img { min-height: 260px; order: 0 !important; }
      .split-text { padding: 40px 26px; }
    }

    /* ─── PROOF BLOCK ──────────────────────────────────── */
    .proof { background: var(--light-bg); padding: 64px 0; margin-top: 48px; }
    .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .proof-item { padding-left: 18px; border-left: 3px solid var(--blue); }
    .proof-key { font-family: var(--font-display); font-weight: 400; font-size: 2.6rem; line-height: 1; letter-spacing: 0.5px; color: var(--navy); }
    .proof-line { font-family: var(--font-body); font-size: 0.96rem; line-height: 1.5; color: #3a444f; margin-top: 10px; }

    /* ─── SERVICE AREAS ────────────────────────────────── */
    .areas { padding: 72px 0; text-align: center; }
    .areas h2 { font-size: clamp(28px, 3.6vw, 44px); color: var(--navy); }
    .areas .section-eyebrow { display: block; }
    .areas-sub { font-family: var(--font-body); font-size: 1.02rem; color: var(--muted); margin-top: 12px; max-width: 640px; margin-left: auto; margin-right: auto; }
    .chips { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 30px; }
    .chip { background: var(--light-bg); border: 1px solid var(--border); border-radius: 24px; padding: 10px 20px; font-family: var(--font-heading); font-size: 0.9rem; font-weight: 600; color: var(--navy); transition: background 0.15s, color 0.15s, border-color 0.15s; }
    .chip:hover { background: var(--blue); color: #fff; border-color: var(--blue); text-decoration: none; }

    /* ─── GRADIENT CTA BAND ────────────────────────────── */
    .cta-wrap { padding: 0 0 80px; }
    .cta-band {
      max-width: 1100px; margin: 0 auto; border-radius: 16px;
      background: linear-gradient(135deg, #122538 0%, var(--navy) 45%, #3c6ea4 100%);
      padding: 46px 52px; display: flex; align-items: center; justify-content: space-between; gap: 28px; flex-wrap: wrap;
      box-shadow: 0 20px 50px rgba(27,58,92,0.22);
    }
    .cta-band h2 { font-family: var(--font-display); font-weight: 400; font-size: clamp(26px, 3.4vw, 40px); letter-spacing: 0.5px; text-transform: uppercase; color: #fff; line-height: 1.06; }
    .cta-band .cta-actions { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; }
    .cta-call { font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; color: rgba(255,255,255,0.85); }
    .cta-call a { color: #fff; }
    @media (max-width: 700px) { .cta-band { padding: 36px 26px; } }

    /* ─── STICKY BAR ───────────────────────────────────── */
    .sticky-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 998; background: rgba(27,58,92,0.97); backdrop-filter: blur(8px); border-top: 2px solid var(--red); padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; gap: 16px; transform: translateY(100%); transition: transform 0.3s ease; }
    .sticky-bar.visible { transform: translateY(0); }
    .sticky-bar p { font-family: var(--font-body); font-size: 15px; color: rgba(255,255,255,0.88); font-weight: 600; }
    .sticky-bar a { background: var(--red); color: var(--white); padding: 11px 24px; border-radius: 100px; font-family: var(--font-heading); font-size: 14px; font-weight: 700; white-space: nowrap; flex-shrink: 0; text-transform: uppercase; letter-spacing: 0.5px; }
    .sticky-bar a:hover { background: var(--red-dark); text-decoration: none; }

    /* ─── RESPONSIVE ───────────────────────────────────── */
    @media (max-width: 980px) {
      .action-grid, .svc-grid { grid-template-columns: repeat(2, 1fr); }
      .proof-grid { grid-template-columns: repeat(2, 1fr); gap: 22px 28px; max-width: 640px; margin: 0 auto; }
    }
    @media (max-width: 600px) {
      .hero { padding: 56px 0 60px; }
      .action-wrap { padding: 32px 0; }
      .action-grid, .svc-grid { grid-template-columns: 1fr; }
      .cta-band { flex-direction: column; align-items: flex-start; }
      .sticky-bar { flex-direction: column; padding: 14px 20px; gap: 10px; }
      .sticky-bar p { text-align: center; font-size: 13px; }
      .sticky-bar a { width: 100%; text-align: center; }
    }
  </style>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <div class="inner hero-inner">
      <h1 class="anton">Honest Heating &amp; Cooling<br />For the Greater Charlotte Area</h1>
      <p class="hero-sub">Family-owned HVAC repair, installation, and maintenance for Union County and the greater Charlotte metro. Licensed, insured, and on call 24/7 &mdash; with a flat price before we touch anything.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-pill">Get a Free Estimate
          <span class="pill-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
        </a>
        <a href="tel:+19802807570" class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (980) 280-7570
        </a>
      </div>
      <div class="hero-stars">
        <span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="txt">Five-Star Rated on Google</span>
      </div>
    </div>
    <img class="hero-watermark" src="/images/bryant-logo-transparent.png" alt="" aria-hidden="true" />
  </section>

  <!-- ═══ ACTION CARDS ═══ -->
  <div class="action-wrap">
    <div class="inner action-grid">
      <a href="/contact" class="action-card red">
        <svg class="ac-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/></svg>
        <span class="ac-title">Book Your<br />Service</span>
        <span class="ac-sub">Get comfort today &rarr;</span>
      </a>
      <a href="/ac-repair-monroe-nc" class="action-card blue">
        <svg class="ac-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="2" x2="12" y2="22"/><line x1="4" y1="7" x2="20" y2="17"/><line x1="20" y1="7" x2="4" y2="17"/><polyline points="9 4 12 2 15 4"/><polyline points="9 20 12 22 15 20"/></svg>
        <span class="ac-title">AC<br />Repair</span>
        <span class="ac-sub">Get a free estimate &rarr;</span>
      </a>
      <a href="/furnace-repair-monroe-nc" class="action-card light">
        <svg class="ac-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
        <span class="ac-title">Heating &amp;<br />Furnace</span>
        <span class="ac-sub">Get a free estimate &rarr;</span>
      </a>
      <a href="/hvac-installation-monroe-nc" class="action-card blue">
        <svg class="ac-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="2" x2="12" y2="12"/><path d="M18.4 6.6a9 9 0 1 1-12.77.04"/></svg>
        <span class="ac-title">New System<br />Install</span>
        <span class="ac-sub">Get a free estimate &rarr;</span>
      </a>
    </div>
  </div>

  <!-- ═══ SERVICES BAND ═══ -->
  <section class="services-band" id="services">
    <div class="inner">
      <div class="services-head">
        <p class="section-eyebrow">What We Do</p>
        <h2 class="anton">Your Trusted HVAC Team<br />in Union County &amp; Charlotte</h2>
        <div class="divider">
          <span class="line"></span>
          <svg class="gear" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm9.4 4l1.5 1.2-1.5 2.6-1.9-.5a7.7 7.7 0 0 1-1.4.8l-.3 1.9h-3l-.3-1.9a7.7 7.7 0 0 1-1.4-.8l-1.9.5L7.2 15.2 8.7 14a7.5 7.5 0 0 1 0-1.6L7.2 11.2l1.5-2.6 1.9.5a7.7 7.7 0 0 1 1.4-.8l.3-1.9h3l.3 1.9c.5.2 1 .5 1.4.8l1.9-.5 1.5 2.6L21.4 12z"/></svg>
          <span class="line"></span>
        </div>
      </div>
      <div class="svc-grid">
        <a href="/ac-repair-monroe-nc" class="svc-card">
          <svg class="svc-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="2" x2="12" y2="22"/><line x1="4" y1="7" x2="20" y2="17"/><line x1="20" y1="7" x2="4" y2="17"/><polyline points="9 4 12 2 15 4"/><polyline points="9 20 12 22 15 20"/><polyline points="4 11 4 7 8 7"/><polyline points="20 13 20 17 16 17"/></svg>
          <h3>Air Conditioning</h3>
          <p>Same-day AC repair, recharge, and replacement.</p>
        </a>
        <a href="/furnace-repair-monroe-nc" class="svc-card">
          <svg class="svc-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
          <h3>Heating</h3>
          <p>Furnace repair, tune-ups, and fast diagnostics.</p>
        </a>
        <a href="/heat-pump-service-monroe-nc" class="svc-card">
          <svg class="svc-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M14 14.76V5a2 2 0 1 0-4 0v9.76a4 4 0 1 0 4 0z"/></svg>
          <h3>Heat Pumps</h3>
          <p>Year-round comfort, expert service and installs.</p>
        </a>
        <a href="/hvac-maintenance-monroe-nc" class="svc-card">
          <svg class="svc-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.6 2.6-2.1-.5-.5-2.1 2.7-2.5z"/></svg>
          <h3>Maintenance</h3>
