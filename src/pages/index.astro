---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---
<Base
  title="Bryant Heating &amp; Cooling | HVAC Monroe NC"
  description="Monroe NC's honest HVAC company. AC repair, furnace service, installation — licensed #18740, 24/7, no diagnostic fee. Call (980) 280-7570."
  canonical="https://bryanthvacpros.com"
>
  <fragment slot="header">
    <nav class="bhc-nav">
      <a href="/" class="nav-logo">
        <img src="/images/bryant-hvac-logo.webp" alt="Bryant Heating and Cooling Monroe NC" style="height:44px; width:auto; display:block;" />
      </a>
      <div class="nav-right">
        <a href="tel:+19802807570" class="nav-phone">(980) 280-7570</a>
        <a href="tel:+19802807570" class="nav-cta">Call Now</a>
      </div>
      <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/service-areas">Services</a>
      <a href="/about">About Us</a>
      <a href="/service-areas">Service Areas</a>
      <a href="/contact">Contact</a>
      <a href="tel:+19802807570" class="mobile-cta">Call (980) 280-7570</a>
    </div>
  </fragment>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    :root {
      --red: #C41E1E; --red-dark: #A31818;
      --blue: #5B8AB5; --navy: #1B3A5C;
      --light-bg: #F0F4F8; --text: #2A2A2A;
      --muted: #666666; --border: #E2E8EF; --white: #FFFFFF;
    }
    body { font-family: 'Barlow', sans-serif; color: var(--text); background: var(--white); overflow-x: hidden; }

    /* NAV */
    .bhc-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 999;
      height: 68px; background: rgba(255,255,255,0.97);
      backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 0 48px; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-right { display: flex; align-items: center; gap: 20px; }
    .nav-phone { font-size: 16px; font-weight: 700; color: var(--navy); text-decoration: none; letter-spacing: 0.3px; }
    .nav-phone:hover { color: var(--red); }
    .nav-cta { background: var(--red); color: var(--white); padding: 10px 20px; border-radius: 4px; font-size: 14px; font-weight: 700; text-decoration: none; white-space: nowrap; }
    .nav-cta:hover { background: var(--red-dark); }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
    .nav-hamburger span { display: block; width: 24px; height: 2px; background: var(--navy); border-radius: 2px; }
    .mobile-menu { display: none; position: fixed; inset: 68px 0 0 0; z-index: 998; background: var(--white); flex-direction: column; align-items: center; justify-content: center; gap: 32px; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 20px; font-weight: 700; color: var(--navy); text-decoration: none; }
    .mobile-menu a:hover { color: var(--red); }
    .mobile-menu .mobile-cta { background: var(--red); color: var(--white); padding: 14px 32px; border-radius: 4px; font-size: 18px; }

    @media (max-width: 768px) {
      .bhc-nav { padding: 0 20px; }
      .nav-phone, .nav-cta { display: none; }
      .nav-hamburger { display: flex; }
    }

    /* HERO */
    .hero {
      position: relative; min-height: 620px; display: flex; align-items: center;
      padding-top: 68px;
      background: linear-gradient(135deg, rgba(27,58,92,0.88) 0%, rgba(91,138,181,0.65) 100%), url('/images/bryant-hvac-hero.webp') center/cover no-repeat;
    }
    .hero-inner { max-width: 700px; margin: 0 auto; padding: 80px 48px; position: relative; z-index: 1; }
    .hero-inner h1 { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(36px, 5vw, 58px); font-weight: 800; line-height: 1.1; color: var(--white); letter-spacing: 0.5px; text-transform: uppercase; }
    .hero-inner p { font-size: 18px; color: rgba(255,255,255,0.85); margin-top: 16px; line-height: 1.6; max-width: 520px; }
    .hero-cta { display: inline-block; margin-top: 28px; background: var(--red); color: var(--white); padding: 16px 32px; border-radius: 4px; font-size: 18px; font-weight: 800; text-decoration: none; letter-spacing: 0.5px; animation: cta-pulse 3.5s ease-in-out infinite; }
    .hero-cta:hover { background: var(--red-dark); animation-play-state: paused; }
    @keyframes cta-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(196,30,30,0); }
      50% { box-shadow: 0 0 0 10px rgba(196,30,30,0.22), 0 0 32px rgba(196,30,30,0.14); }
    }
    @media (max-width: 768px) { .hero { min-height: 520px; } .hero-inner { padding: 60px 20px; } .hero-inner h1 { font-size: 34px; } }

    /* STAT BAR */
    .stat-bar-bg { background: var(--white); border-bottom: 3px solid var(--red); }
    .stat-bar { max-width: 1100px; margin: 0 auto; padding: 0 48px; display: flex; }
    .stat-item { flex: 1; padding: 20px 16px; text-align: center; border-right: 1px solid var(--border); }
    .stat-item:last-child { border-right: none; }
    .stat-item strong { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 26px; font-weight: 800; color: var(--red); }
    .stat-item span { font-size: 13px; color: var(--muted); font-weight: 600; }
    @media (max-width: 600px) { .stat-bar { flex-direction: column; padding: 0 20px; } .stat-item { border-right: none; border-bottom: 1px solid var(--border); padding: 16px 12px; } .stat-item:last-child { border-bottom: none; } }

    /* SERVICES */
    .services-bg { background: var(--light-bg); }
    .services-inner { max-width: 1100px; margin: 0 auto; padding: 80px 48px; }
    .section-label { font-size: 12px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
    .section-title { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(28px, 3.5vw, 40px); font-weight: 800; color: var(--navy); line-height: 1.1; margin-bottom: 40px; }
    .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .service-card { background: var(--white); border-radius: 6px; padding: 28px 28px 28px 24px; border-left: 4px solid var(--blue); box-shadow: 0 2px 8px rgba(27,58,92,0.07); text-decoration: none; display: block; transition: box-shadow 0.2s, transform 0.15s; }
    .service-card:hover { box-shadow: 0 6px 20px rgba(27,58,92,0.12); transform: translateY(-2px); }
    .service-card h3 { font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .service-card p { font-size: 14px; color: var(--muted); }
    @media (max-width: 640px) { .services-grid { grid-template-columns: 1fr; } .services-inner { padding: 56px 20px; } }

    /* WHY BRYANT */
    .why-bg { background: var(--navy); }
    .why-inner { max-width: 1100px; margin: 0 auto; padding: 80px 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .why-text .section-label { color: var(--blue); }
    .why-text .section-title { color: var(--white); }
    .why-copy { font-size: 17px; color: rgba(255,255,255,0.80); line-height: 1.75; margin-bottom: 36px; }
    .trust-badges { display: flex; flex-wrap: wrap; gap: 12px; }
    .trust-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); border-radius: 4px; padding: 10px 16px; font-size: 13px; font-weight: 700; color: var(--white); }
    .trust-badge::before { content: ''; display: block; width: 8px; height: 8px; border-radius: 50%; background: var(--red); flex-shrink: 0; }
    .why-visual { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; padding: 40px 32px; text-align: center; }
    .why-visual-number { font-family: 'Barlow Condensed', sans-serif; font-size: 72px; font-weight: 800; color: var(--red); line-height: 1; }
    .why-visual-label { font-size: 15px; color: rgba(255,255,255,0.65); margin-top: 8px; font-weight: 600; }
    .why-visual-sub { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 6px; }
    @media (max-width: 768px) { .why-inner { grid-template-columns: 1fr; gap: 40px; padding: 56px 20px; } }

    /* SERVICE AREAS */
    .areas-bg { background: var(--white); }
    .areas-inner { max-width: 1100px; margin: 0 auto; padding: 80px 48px; text-align: center; }
    .city-chips { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 32px; }
    .city-chip { background: var(--light-bg); border: 1px solid var(--border); border-radius: 24px; padding: 10px 20px; font-size: 14px; font-weight: 600; color: var(--navy); text-decoration: none; display: inline-block; transition: background 0.15s, border-color 0.15s, color 0.15s; }
    .city-chip:hover { background: var(--blue); color: var(--white); border-color: var(--blue); }
    @media (max-width: 768px) { .areas-inner { padding: 56px 20px; } }

    /* CONTACT CTA */
    .contact-bg { background: var(--red); }
    .contact-inner { max-width: 1100px; margin: 0 auto; padding: 80px 48px; text-align: center; }
    .contact-inner h2 { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(32px, 4vw, 48px); font-weight: 800; color: var(--white); text-transform: uppercase; letter-spacing: 0.5px; }
    .contact-inner p { font-size: 17px; color: rgba(255,255,255,0.85); margin-top: 12px; line-height: 1.6; }
    .contact-phone { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: clamp(42px, 6vw, 64px); font-weight: 800; color: var(--white); text-decoration: none; letter-spacing: 1px; margin-top: 24px; line-height: 1; }
    .contact-phone:hover { opacity: 0.85; }
    .contact-cta-btn { display: inline-block; margin-top: 24px; background: var(--white); color: var(--red); padding: 16px 40px; border-radius: 4px; font-size: 17px; font-weight: 800; text-decoration: none; letter-spacing: 0.5px; }
    .contact-cta-btn:hover { background: rgba(255,255,255,0.9); }
    @media (max-width: 768px) { .contact-inner { padding: 56px 20px; } }

    /* STICKY BAR */
    .sticky-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 998; background: rgba(27,58,92,0.97); backdrop-filter: blur(8px); border-top: 2px solid var(--red); padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; gap: 16px; transform: translateY(100%); transition: transform 0.3s ease; }
    .sticky-bar.visible { transform: translateY(0); }
    .sticky-bar p { font-size: 15px; color: rgba(255,255,255,0.85); font-weight: 600; }
    .sticky-bar a { background: var(--red); color: var(--white); padding: 11px 24px; border-radius: 4px; font-size: 15px; font-weight: 800; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
    .sticky-bar a:hover { background: var(--red-dark); }
    @media (max-width: 600px) { .sticky-bar { flex-direction: column; padding: 14px 20px; gap: 10px; } .sticky-bar p { font-size: 13px; text-align: center; } .sticky-bar a { width: 100%; text-align: center; } }
  </style>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-inner">
      <h1>AC Down in Monroe?<br>We Pick Up Every Call.</h1>
      <p>A family-run company that shows up when you call — same-day service across Monroe and Union County.</p>
      <a href="tel:+19802807570" class="hero-cta">Call 980-280-7570</a>
    </div>
  </section>

  <!-- STAT BAR -->
  <div class="stat-bar-bg">
    <div class="stat-bar">
      <div class="stat-item"><strong>24/7</strong><span>Emergency Service</span></div>
      <div class="stat-item"><strong>Same-Day</strong><span>Most Repairs</span></div>
      <div class="stat-item"><strong>Family-Run</strong><span>Not a Franchise</span></div>
    </div>
  </div>

  <!-- SERVICES -->
  <section class="services-bg" id="services">
    <div class="services-inner">
      <p class="section-label">What We Do</p>
      <h2 class="section-title">HVAC Services in<br>Monroe &amp; Union County</h2>
      <div class="services-grid">
        <a href="/ac-repair-monroe-nc" class="service-card">
          <h3>AC Repair &amp; Maintenance</h3>
          <p>Monroe &amp; Union County — same-day service available</p>
        </a>
        <a href="/furnace-repair-monroe-nc" class="service-card">
          <h3>Heating Repair</h3>
          <p>Furnace &amp; heat pump — fast diagnosis, honest fix</p>
        </a>
        <a href="/hvac-installation-monroe-nc" class="service-card">
          <h3>HVAC Installation</h3>
          <p>All major brands — sized and installed for your home</p>
        </a>
        <a href="/heat-pump-service-monroe-nc" class="service-card">
          <h3>Emergency Service</h3>
          <p>Nights &amp; weekends — we pick up, we show up</p>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY BRYANT -->
  <section class="why-bg" id="why-bryant">
    <div class="why-inner">
      <div class="why-text">
        <p class="section-label">Why Bryant</p>
        <h2 class="section-title">Monroe's HVAC<br>Company You Can Trust</h2>
        <p class="why-copy">When your AC goes out, the last thing you need is a call center upselling you parts you don't need. Bryant is Monroe's local HVAC company — family-run, relationship-first, and always a straight answer on what your system actually needs.</p>
        <div class="trust-badges">
          <span class="trust-badge">Licensed &amp; Insured (NC #18740)</span>
          <span class="trust-badge">Family-Owned &amp; Operated</span>
          <span class="trust-badge">Same-Day Service Available</span>
          <span class="trust-badge">No Diagnostic Fee</span>
        </div>
      </div>
      <div class="why-visual">
        <div class="why-visual-number">24/7</div>
        <div class="why-visual-label">We Answer the Phone</div>
        <div class="why-visual-sub">Nights, weekends, and holidays</div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="areas-bg" id="service-areas">
    <div class="areas-inner">
      <p class="section-label">Where We Work</p>
      <h2 class="section-title">Serving Monroe &amp; Union County</h2>
      <div class="city-chips">
        <a href="/cities/hvac-monroe-nc" class="city-chip">Monroe</a>
        <a href="/cities/hvac-monroe-nc" class="city-chip">Unionville</a>
        <a href="/cities/hvac-monroe-nc" class="city-chip">Marshville</a>
        <a href="/cities/hvac-monroe-nc" class="city-chip">Wingate</a>
        <a href="/cities/hvac-waxhaw-nc" class="city-chip">Waxhaw</a>
        <a href="/cities/hvac-monroe-nc" class="city-chip">Stallings</a>
        <a href="/cities/hvac-indian-trail-nc" class="city-chip">Indian Trail</a>
        <a href="/cities/hvac-monroe-nc" class="city-chip">Mint Hill</a>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <ContactForm heading="Request Service Online" />

  <!-- CONTACT CTA -->
  <section class="contact-bg" id="contact">
    <div class="contact-inner">
      <h2>Ready to Book? Call Us Directly.</h2>
      <p>No voicemail. No hold music. Real people, real answers.</p>
      <a href="tel:+19802807570" class="contact-phone">(980) 280-7570</a>
      <br />
      <a href="tel:+19802807570" class="contact-cta-btn">Call Now — We'll Pick Up</a>
    </div>
  </section>

  <!-- FOOTER (custom homepage footer) -->
  <fragment slot="footer">
    <footer style="background:var(--navy);">
      <div style="max-width:1100px; margin:0 auto; padding:48px 48px 32px; display:grid; grid-template-columns:2fr 1fr 1fr; gap:48px;">
        <div>
          <img src="/images/bryant-hvac-logo.webp" alt="Bryant Heating and Cooling" style="height:48px; width:auto; margin-bottom:16px;" />
          <p style="font-size:13px; color:rgba(255,255,255,0.60); line-height:1.8;">
            Bryant Heating &amp; Cooling<br>
            7923 Morgan Mill Road<br>
            Monroe, NC 28110<br>
            <a href="tel:+19802807570" style="color:rgba(255,255,255,0.60);">(980) 280-7570</a><br>
            <a href="mailto:bryanthvacpro@gmail.com" style="color:rgba(255,255,255,0.60);">bryanthvacpro@gmail.com</a>
          </p>
        </div>
        <div>
          <h4 style="font-size:11px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:rgba(255,255,255,0.40); margin-bottom:16px;">Services</h4>
          <ul style="list-style:none;">
            <li style="margin-bottom:10px;"><a href="/ac-repair-monroe-nc" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">AC Repair</a></li>
            <li style="margin-bottom:10px;"><a href="/furnace-repair-monroe-nc" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">Heating Repair</a></li>
            <li style="margin-bottom:10px;"><a href="/hvac-installation-monroe-nc" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">HVAC Installation</a></li>
            <li style="margin-bottom:10px;"><a href="/heat-pump-service-monroe-nc" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">Heat Pump Service</a></li>
          </ul>
        </div>
        <div>
          <h4 style="font-size:11px; font-weight:800; letter-spacing:1.5px; text-transform:uppercase; color:rgba(255,255,255,0.40); margin-bottom:16px;">Company</h4>
          <ul style="list-style:none;">
            <li style="margin-bottom:10px;"><a href="/about" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">About Us</a></li>
            <li style="margin-bottom:10px;"><a href="/service-areas" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">Service Areas</a></li>
            <li style="margin-bottom:10px;"><a href="/contact" style="font-size:14px; color:rgba(255,255,255,0.70); text-decoration:none;">Contact</a></li>
          </ul>
        </div>
      </div>
      <div style="max-width:1100px; margin:0 auto; padding:20px 48px; border-top:1px solid rgba(255,255,255,0.10); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
        <p style="font-size:12px; color:rgba(255,255,255,0.35);">© 2026 Bryant Heating &amp; Cooling of the Piedmont, LLC. All rights reserved.</p>
        <div style="display:flex; gap:20px;">
          <a href="/privacy-policy" style="font-size:12px; color:rgba(255,255,255,0.45); text-decoration:none;">Privacy Policy</a>
          <a href="/terms-of-service" style="font-size:12px; color:rgba(255,255,255,0.45); text-decoration:none;">Terms of Service</a>
        </div>
      </div>
    </footer>
  </fragment>

  <!-- STICKY BAR -->
  <div class="sticky-bar" id="stickyBar">
    <p>Monroe's local HVAC company — we pick up every call.</p>
    <a href="tel:+19802807570">Call (980) 280-7570</a>
  </div>

  <script is:inline>
    var hamburger = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobileMenu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', function() { mobileMenu.classList.toggle('open'); });
      mobileMenu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() { mobileMenu.classList.remove('open'); });
      });
    }
    (function() {
      var bar = document.getElementById('stickyBar');
      var hero = document.getElementById('hero');
      var contact = document.getElementById('contact');
      if (!bar || !hero || !contact) return;
      function updateBar() {
        var heroBottom = hero.offsetTop + hero.offsetHeight;
        var contactTop = contact.getBoundingClientRect().top + window.scrollY;
        var pastHero = window.scrollY > heroBottom - 80;
        var atContact = (window.scrollY + window.innerHeight) > (contactTop + 80) && window.scrollY < (contactTop + contact.offsetHeight);
        bar.classList.toggle('visible', pastHero && !atContact);
      }
      window.addEventListener('scroll', updateBar, { passive: true });
      var barLink = bar.querySelector('a');
      if (barLink) barLink.addEventListener('click', function() { bar.classList.remove('visible'); });
      updateBar();
    })();
  </script>
</Base>
