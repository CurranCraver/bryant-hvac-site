---
import Base from '../layouts/Base.astro';
---
<Base
  title="Request Received | Bryant Heating & Cooling"
  description="Thanks — we received your request. Bryant HVAC will call you back shortly."
  canonical="https://bryanthvacpros.com/thank-you"
>
  <section style="padding:96px 0; text-align:center;">
    <div class="inner" style="max-width:560px;">
      <h1 style="font-size:3rem; color:var(--navy); margin-bottom:16px;">Request Received</h1>
      <p style="font-size:1.2rem; color:#374151; margin-bottom:32px;">
        We'll call you back shortly at the number you provided.
      </p>
      <p style="font-size:1.1rem; margin-bottom:8px;">
        Need to reach us now? Call <a href="tel:+19802807570">(980) 280-7570</a>
      </p>
      <a href="/"
         style="display:inline-block; margin-top:32px; background:var(--red); color:#fff; padding:12px 28px; border-radius:4px; font-weight:700; text-decoration:none;">
        Back to Home
      </a>
    </div>
  </section>
</Base>
